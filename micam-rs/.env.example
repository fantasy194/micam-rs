MILOCO_BASE_URL=https://127.0.0.1:8000
MILOCO_USERNAME=admin
MILOCO_PASSWORD=your_miloco_password_md5

CAMERA_ID=1234567890
STREAM_CHANNEL=0
VIDEO_CODEC=hevc

RTSP_URL=rtsp://127.0.0.1:8554/your_homekit_stream

# HomeKit-friendly defaults: H.264 video + AAC audio.
# Default GPU path is NVIDIA CUDA/NVENC. Override these for Intel QSV/VAAPI.
FFMPEG_HWACCEL=cuda
FFMPEG_VIDEO_ENCODER=h264_nvenc

TZ=Asia/Shanghai
RUST_LOG=info

