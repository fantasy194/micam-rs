# native removes the Miloco service from the runtime path.
# Set remote to use the old Miloco WebSocket bridge path.
MILOCO_MODE=native

MILOCO_BASE_URL=https://127.0.0.1:8000
MILOCO_USERNAME=admin
MILOCO_PASSWORD=your_miloco_password_md5

CAMERA_ID=1234567890
STREAM_CHANNEL=0
VIDEO_CODEC=h264

RTSP_URL=rtsp://127.0.0.1:8554/your_homekit_stream

# Lowest CPU path for native H.264 streams: copy video without transcoding.
FFMPEG_GPU_ENABLED=false
FFMPEG_HWACCEL=qsv
FFMPEG_VIDEO_ENCODER=h264_qsv
FFMPEG_VAAPI_DEVICE=/dev/dri/renderD128
FFMPEG_EXTRA_ARGS=
FFMPEG_LOW_LATENCY=true

MIOT_ACCESS_TOKEN=
MIOT_REFRESH_TOKEN=your_xiaomi_home_refresh_token
MIOT_TOKEN_FILE=/config/miot_token.json
MIOT_OAUTH_REDIRECT_URI=https://mico.api.mijia.tech/login_redirect
MIOT_REFRESH_MARGIN_SECONDS=1800
MIOT_OAUTH_BIND=0.0.0.0:18080
MIOT_OAUTH_PUBLIC_BASE_URL=http://127.0.0.1:18080
MIOT_OAUTH_CALLBACK_PATH=/api/miot/xiaomi_home_callback
MIOT_OAUTH_UUID=micam-rs
MIOT_OAUTH_SKIP_CONFIRM=false
MIOT_CLOUD_SERVER=cn
MIOT_CAMERA_MODEL=your_camera_model
MIOT_CHANNEL_COUNT=1
MIOT_VIDEO_QUALITY=2
MIOT_ENABLE_AUDIO=false
MIOT_PIN_CODE=
MIOT_LIB_PATH=/usr/local/lib/libmiot_camera_lite.so
MIOT_QUEUE_CAPACITY=8

TZ=Asia/Shanghai
RUST_LOG=info
